# Workspace-level ignores. The Unity project lives in TArenaUnity3D/, which has
# its own Unity-specific .gitignore for Library, Temp, Recordings, generated
# solution files, and similar Unity output.

# OS/editor noise
.DS_Store
Thumbs.db
Desktop.ini
.vs/
.idea/
.fleet/

# Python/tool caches
__pycache__/
*.pyc

# Local scratch/output folders
/tmp/
/temp/
_codex/tmp/

# Local Git metadata backups created during repository cleanup.
_codex/git-backups/
